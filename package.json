{
  "name": "voyager-vmc",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "postinstall": "node scripts/token-gatekeeper.mjs",
    "dev": "next dev -p 3420",
    "dev:turbo": "next dev --turbopack -p 3420",
    "dev:full": "node scripts/token-gatekeeper.mjs && terrazzo build && next dev -p 3420",
    "prebuild": "node scripts/token-gatekeeper.mjs && terrazzo build",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "tokens:build": "terrazzo build",
    "tokens:check": "node scripts/token-gatekeeper.mjs",
    "tokens:audit": "node scripts/token-gatekeeper.mjs && pnpm exec terrazzo build && pnpm type-check && pnpm lint",
    "tokens:figma-sync": "node scripts/sync-tokens-figma-json.mjs",
    "tokens:studio": "pnpm tokens:figma-sync && node scripts/build-token-studio-json.mjs",
    "tokens:watch": "terrazzo build --watch",
    "kill:node": "powershell -Command \"Get-Process node -ErrorAction SilentlyContinue | Stop-Process -Force\"",
    "verify:pages": "node scripts/verify-routes.mjs",
    "verify:pages:quick": "node scripts/verify-routes.mjs --skip-build",
    "wireframe:parity": "node scripts/wireframe-parity-check.mjs",
    "screenshots:canonical": "node scripts/generate-canonical-screenshots.mjs",
    "jira:sync": "node scripts/jira-ops-agent/index.mjs",
    "jira:dry-run": "node scripts/jira-ops-agent/index.mjs --dry-run",
    "jira:state": "node scripts/jira-ops-agent/index.mjs --state",
    "audit:a11y": "node scripts/a11y-audit.mjs",
    "audit:a11y:json": "node scripts/a11y-audit.mjs --json",
    "audit:a11y:patch": "node scripts/a11y-audit.mjs --patch"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.3.0",
    "async-mutex": "^0.5.0",
    "clsx": "^2.1.1",
    "next": "16.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.1.2",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@terrazzo/cli": "^2.0.2",
    "@terrazzo/plugin-css": "^2.0.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "apca-w3": "^0.1.9",
    "axe-core": "^4.11.4",
    "colorjs.io": "^0.6.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.3",
    "typescript": "^5.7.2"
  }
}
