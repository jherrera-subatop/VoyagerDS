{
  "name": "voyager-vmc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/token-gatekeeper.mjs && pnpm exec terrazzo build",
    "predev": "node scripts/token-gatekeeper.mjs && terrazzo build",
    "dev": "next dev -p ${PORT:-3420}",
    "dev:turbo": "next dev --turbopack -p ${PORT:-3420}",
    "prebuild": "node scripts/token-gatekeeper.mjs && terrazzo build",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "tokens:build": "terrazzo build",
    "tokens:check": "node scripts/token-gatekeeper.mjs",
    "tokens:audit": "node scripts/token-gatekeeper.mjs && pnpm exec terrazzo build && pnpm type-check && pnpm lint",
    "tokens:watch": "terrazzo build --watch",
    "verify:pages": "node scripts/verify-routes.mjs",
    "verify:pages:quick": "node scripts/verify-routes.mjs --skip-build"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.3.0",
    "async-mutex": "^0.5.0",
    "clsx": "^2.1.1",
    "next": "15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.1.2",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@terrazzo/cli": "^2.0.2",
    "@terrazzo/plugin-css": "^2.0.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.3",
    "typescript": "^5.7.2"
  }
}
