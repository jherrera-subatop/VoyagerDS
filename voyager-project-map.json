    {
      "id": "ib-taxonomia",
      "jira": "VD-1",
      "title": "Fase 1 · Taxonomía",
      "emoji": "🗂️",
      "status": "in-progress",
      "summary": "Auditoría frame-a-frame de componentes. Nombre canónico, dominio, decisión, variantes.",
      "progress": "Marco Detalle completado (22 componentes). Listing y Home pendientes.",
      "outputArtifact": "TAXONOMY.md"
    },
    {
      "id": "ib-fundamentos",
      "jira": "VD-2",
      "title": "Fase 2 · Tokens y pipeline",
      "emoji": "🎨",
      "status": "done",
      "summary": "Pipeline W3C DTCG → Terrazzo → CSS → Tailwind v4. 3 capas: primitivos / semánticos / componente.",
      "progress": "Completada. Pipeline operativo, gatekeeper activo en predev/prebuild.",
      "outputArtifact": "tokens.json + tokens.css"
    },
    {
      "id": "ib-componentes",
      "jira": "VD-3",
      "title": "Fase 3 · Construcción",
      "emoji": "🔧",
      "status": "todo",
      "summary": "Construir cada componente del inventario en src/features/ según prioridad P0→P4.",
      "progress": "Pendiente. Arrancar con P0: Button, Badge, PriceDisplay, CountdownTimer.",
      "outputArtifact": "src/features/{componentId}/"
    },
    {
      "id": "ib-handoff",
      "jira": "VD-4",
      "title": "Fase 4 · Handoff a código",
      "emoji": "🚀",
      "status": "todo",
      "summary": "Documentar cada componente para consumo sin fricción: props API, tokens, ejemplos, restricciones.",
      "progress": "Bloqueada por ib-componentes. Inicia cuando P0 y P1 estén aprobados en PR.",
      "outputArtifact": "Storybook + README por componente"
    },
    {
      "id": "ib-optimization",
      "jira": "VD-5",
      "title": "Optimización Multi-Agente",
      "emoji": "⚡",
      "status": "in-progress",
      "summary": "Optimizar flujo Claude Code → Cursor. Context architecture, handoff scripts, .mdc rules, scheduled tasks.",
      "progress": "En progreso paralelo. Jira ops-agent activo (sync 9am + 4pm diario).",
      "outputArtifact": "scripts/jira-ops-agent/ + .claude/skills/"
    }
  ],
